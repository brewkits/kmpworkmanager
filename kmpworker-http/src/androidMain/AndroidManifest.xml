<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        INTERNET is required by the built-in HTTP workers (Ktor OkHttp engine) to perform
        network requests. Merged automatically into the consumer app's manifest.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        ACCESS_NETWORK_STATE lets the HTTP workers honor network constraints / reachability.
    -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

</manifest>
